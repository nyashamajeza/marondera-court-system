<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User - Marondera Court</title>
    <style>/* Same as new-user */</style>
</head>
<body>
    <nav class="navbar">...</nav>
    <aside class="sidebar">...</aside>
    <main class="main-content">
        <div class="page-header"><h1>Edit User: <%= editUser.username %></h1></div>
        <div class="form-container">
            <form method="POST" action="/admin/users/<%= editUser._id %>">
                <div class="form-group">
                    <label>Full Name *</label>
                    <input type="text" name="name" value="<%= editUser.name %>" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" value="<%= editUser.email || '' %>">
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select name="role">
                        <option value="Clerk" <%= editUser.role === 'Clerk' ? 'selected' : '' %>>Clerk</option>
                        <option value="Magistrate" <%= editUser.role === 'Magistrate' ? 'selected' : '' %>>Magistrate</option>
                        <option value="Admin" <%= editUser.role === 'Admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>
                        <input type="checkbox" name="isActive" <%= editUser.isActive ? 'checked' : '' %>> Active
                    </label>
                </div>
                <button type="submit" class="btn-save">Update User</button>
                <a href="/admin/users" class="btn-cancel">Cancel</a>
            </form>
        </div>
    </main>
</body>
</html>